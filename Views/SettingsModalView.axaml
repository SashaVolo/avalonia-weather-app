<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:avalonia_dz_templates.ViewModels"
        x:Class="avalonia_dz_templates.Views.SettingsModalView"
        x:DataType="vm:MainWindowViewModel"
        Title="Settings"
        Width="850" Height="650"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        Background="#3B4032">

    <Grid RowDefinitions="70, *">

        <Grid Grid.Row="0" Margin="30, 20, 30, 0" ColumnDefinitions="*, Auto">
            <TextBlock Grid.Column="0" Text="Settings" FontSize="26" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="✕" Click="Close_Click" Background="Transparent" Foreground="#AAAAAA" FontSize="20" VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="220, *" Margin="30, 20, 30, 30">

            <StackPanel Grid.Column="0" Spacing="10">
                <Button Content="City search" Background="#33000000" Foreground="White" Width="180" HorizontalAlignment="Left" CornerRadius="5" Padding="15, 10"/>
                <Button Content="App size" Background="Transparent" Foreground="#888888" Width="180" HorizontalAlignment="Left" Padding="15, 10"/>
                <Button Content="App language" Background="Transparent" Foreground="#888888" Width="180" HorizontalAlignment="Left" Padding="15, 10"/>
                <Button Content="Saved lists" Background="Transparent" Foreground="#888888" Width="180" HorizontalAlignment="Left" Padding="15, 10"/>
            </StackPanel>

            <Grid Grid.Column="1" RowDefinitions="Auto, *">

                <Grid Grid.Row="0" ColumnDefinitions="*, *">
                    <StackPanel Grid.Column="0" Spacing="15" Margin="0, 0, 20, 0">
                        <TextBlock Text="City search" FontSize="20" Foreground="White" Margin="0, 0, 0, 10"/>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Country" Foreground="White" FontWeight="SemiBold"/>
                            <ComboBox PlaceholderText="Select country" HorizontalAlignment="Stretch"
                                      Background="#33000000" Foreground="White" BorderThickness="1" BorderBrush="#44FFFFFF" CornerRadius="5"
                                      ItemsSource="{Binding AvailableCountries}"
                                      SelectedItem="{Binding SelectedCountry}"
                                      MaxDropDownHeight="150"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="City" Foreground="White" FontWeight="SemiBold"/>
                            <ComboBox PlaceholderText="Select city" HorizontalAlignment="Stretch"
                                      Background="#33000000" Foreground="White" BorderThickness="1" BorderBrush="#44FFFFFF" CornerRadius="5"
                                      ItemsSource="{Binding CitiesForSelectedCountry}"
                                      SelectedItem="{Binding SelectedNewCity}"
                                      MaxDropDownHeight="150"/>
                        </StackPanel>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Coordinates" Foreground="White" FontWeight="SemiBold"/>
                            <TextBox Watermark="(WGS 84,UTM,MGRS)"
                                     Background="#33000000" Foreground="White" BorderThickness="1" BorderBrush="#44FFFFFF" CornerRadius="5"
                                     Text="{Binding CoordinatesText}"/>
                        </StackPanel>

                        <Button Content="Save" Background="#2A2A2A" Foreground="#888888" CornerRadius="5" Padding="20, 10" Margin="0, 10, 0, 0"
                                Command="{Binding SaveSettingsCityCommand}"/>
                    </StackPanel>

                    <Border Grid.Column="1" CornerRadius="8" ClipToBounds="True" Background="#E0E0E0" Height="220" VerticalAlignment="Bottom">
                        <TextBlock Text="Map preview" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray"/>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="1" Margin="0, 30, 0, 0">
                    <TextBlock Text="Added cities" FontSize="20" Foreground="White" Margin="0, 0, 0, 15"/>

                    <Border Background="#33000000" CornerRadius="8" Padding="10">
                        <ItemsControl ItemsSource="{Binding Cities}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*, Auto" Margin="10, 15">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="White" FontSize="16" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="Delete" Background="Transparent" Foreground="#FF5F56" FontSize="14" FontWeight="SemiBold" Command="{Binding $parent[Window].DataContext.DeleteCityCommand}" CommandParameter="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>

            </Grid>
        </Grid>
    </Grid>
</Window>