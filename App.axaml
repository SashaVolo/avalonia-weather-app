<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="avalonia_dz_templates.App"
             xmlns:local="using:avalonia_dz_templates"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="SemiTransparentBackground" Color="#33000000" />
                    
                    <SolidColorBrush x:Key="SidebarBackground" Color="#66000000" />
                    <SolidColorBrush x:Key="BlocksBackgroud" Color="#33000000" />
                    <SolidColorBrush x:Key="MainTextForeground" Color="White" />
                    <SolidColorBrush x:Key="DividerColor" Color="White" />
                    <LinearGradientBrush x:Key="MainAppBackground" StartPoint="0%, 100%" EndPoint="100%, 0%">
                        <GradientStop Offset="0.05" Color="#87CEFA"/>
                        <GradientStop Offset="1.0" Color="#FFDF56"/>
                    </LinearGradientBrush>
                    <Thickness x:Key="SwitchThumbMargin">34,0,0,0</Thickness>
                    <SolidColorBrush x:Key="SwitchThumbColor" Color= "#333333" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="SemiTransparentBackground" Color="#33FFFFFF" />
                    <SolidColorBrush x:Key="SidebarBackground" Color="#66FFFFFF" />
                    <SolidColorBrush x:Key="BlocksBackgroud" Color="#33ffffff" />
                    <SolidColorBrush x:Key="MainTextForeground" Color="#1C1C1C" />
                    <SolidColorBrush x:Key="DividerColor" Color="#44000000" />
                    <LinearGradientBrush x:Key="MainAppBackground" StartPoint="0%, 100%" EndPoint="100%, 0%">
                        <GradientStop Offset="0.05" Color="#A3D8F4"/>
                        <GradientStop Offset="1.0" Color="#FFE885"/>
                    </LinearGradientBrush>
                    <Thickness x:Key="SwitchThumbMargin">2,0,0,0</Thickness>
                    <SolidColorBrush x:Key="SwitchThumbColor" Color= "White" />

                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <Style Selector="Grid.MainGrid">
            <Setter Property="Background" Value="{DynamicResource MainAppBackground}" />
            <!-- <Setter Property="Width" Value="1200" />
            <Setter Property="Height" Value="800" /> -->
        </Style>

        <Style Selector="Grid.Sidebar">
            <Setter Property="Background" Value="{DynamicResource SidebarBackground}" />
            <!-- <Setter Property="Opacity" Value="0.2" /> -->
            <Setter Property="Width" Value="370" />
            <!-- <Setter Property="Height" Value="800" /> -->
        </Style>

        <Style Selector="Grid.Header">
            <!-- <Setter Property="Width" Value="800" /> -->
            <Setter Property="Height" Value="40" />
            <!-- <Setter Property="Spacing" Value="420"/> -->
        </Style>

        <Style Selector="StackPanel.SettingsBlock">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Spacing" Value="10" />
        </Style>

        <Style Selector="Button.SettingsButton">
            <Setter Property="Background" Value="#33000000" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
        </Style>

        <Style Selector="TextBlock.SettingsLabel">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="AutoCompleteBox.SearchInput">
            <Setter Property="Width" Value="200" />
            <Setter Property="Height" Value="30" />
        </Style>

        <Style Selector="Grid.ContentBlock">
            <Setter Property="Height" Value="300" />
        </Style>

        <Style Selector="Grid.WeatherInfoAboutSelectedCity">
            <Setter Property="Width" Value="400" />
            <Setter Property="Height" Value="300" />
            <Setter Property="Background" Value="#33000000" />

        </Style>

        <Style Selector="Grid.TimeBlock">
            <Setter Property="Width" Value="400" />
            <Setter Property="Height" Value="300" />
            <Setter Property="Background" Value="#33000000" />

        </Style>

        <Style Selector="Grid.WeatherInfoForDays">
         <Setter Property="Width" Value="800" />
            <Setter Property="Height" Value="160" />
            <Setter Property="Background" Value="#33000000" />
        </Style>

        <Style Selector="Grid.WeatherInfoForHours">
            <Setter Property="Width" Value="800" />
            <Setter Property="Height" Value="160" />
            <Setter Property="Background" Value="#33000000" />
        </Style>
		
		<Style Selector="Border.CurrentWeatherBorder">
            <!-- <Setter Property="Width" Value="390" />
            <Setter Property="Height" Value="300" /> -->
            <Setter Property="Padding" Value="20" />
            <Setter Property="Background" Value="{DynamicResource BlocksBackgroud}" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
        
        <Style Selector="StackPanel.CurrentWeatherContainer">
            
        </Style>
        
        <Style Selector="StackPanel.CWHeader">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Spacing" Value="10" />
        </Style>
        
        <Style Selector="Image.CWHeaderIcon">
            <Setter Property="Width" Value="15" />
            <Setter Property="Height" Value="15" />
        </Style>
        
        <Style Selector="TextBlock.CWHeaderText">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        
        <Style Selector="Border.CWLine">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Opacity" Value="0.3" />
        </Style>
        
        <Style Selector="TextBlock.CWSelectedCity">
            <Setter Property="Margin" Value="0, 0,0,10" />
            <Setter Property="FontSize" Value="48" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        
        <Style Selector="StackPanel.CWWeatherBlock">
            <Setter Property="Spacing" Value="15" />
        </Style>
        
        <Style Selector="Image.CWWeatherIcon">
            <Setter Property="Width" Value="100" />
            <Setter Property="Height" Value="100" />
            <Setter Property="Stretch" Value="Uniform" />
        </Style>
        
        <Style Selector="TextBlock.CWWeatherTemp">
            <Setter Property="FontSize" Value="64" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        
        <Style Selector="TextBlock.CWDescription">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Margin" Value="0,10,0,5" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        
        <Style Selector="TextBlock.CWMinMaxTemp">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Opacity" Value="0.8" />
        </Style>
        
        <Style Selector="StackPanel.CWContent">
        </Style>
        
        <Style Selector="Border.ClBorder">
            <!-- <Setter Property="Width" Value="390" />
            <Setter Property="Height" Value="300" /> -->
            <Setter Property="Padding" Value="20" />
            <Setter Property="Background" Value="{DynamicResource BlocksBackgroud}" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
        
        <Style Selector="StackPanel.ClContainer"></Style>
        
        <Style Selector="StackPanel.ClHeader">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Spacing" Value="10" />
        </Style>
        
        <Style Selector="TextBlock.ClHeaderText">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        
        <Style Selector="StackPanel.ClContent">
            <Setter Property="Spacing" Value="10" />
        </Style>
        
        <Style Selector="DockPanel.ClDayAndDateBlock">
            <Setter Property="Width" Value="370" />
            
        </Style>
        
        <Style Selector="TextBlock.ClDayOfWeek">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        
        <Style Selector="TextBlock.ClDate">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        
        <Style Selector="Grid.ClTimeBlock">
            <Setter Property="Width" Value="170" />
            <Setter Property="Height" Value="170" />
        </Style>
        
        <Style Selector="Image.ClClockImage">
        </Style>
        
        <Style Selector="TextBlock.ClTime">
            <Setter Property="FontSize" Value="29" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        
        
        <!-- <Style Selector="ListBoxItem"> -->
        <!--     <Setter  Property="Background" Value="Transparent"></Setter> -->
        <!-- </Style> -->
        <!-- <Style Selector="ListBoxItem:pointerover"> -->
        <!--     <Setter  Property="Background" Value="Transparent"></Setter> -->
        <!-- </Style> -->
        <!-- <Style Selector="ListBoxItem:selected"> -->
        <!--     <Setter  Property="Background" Value="Transparent"></Setter> -->
        <!-- </Style> -->
        <!-- -->
        <!-- <Style Selector="ListBoxItem:pointerover  > ContentPresenter"> -->
        <!--     <Setter  Property="Background" Value="Transparent"></Setter> -->
        <!-- </Style> -->
        <!-- <Style Selector="ListBoxItem:selected  > ContentPresenter"> -->
        <!--     <Setter  Property="Background" Value="Transparent"></Setter> -->
        <!-- </Style> -->
        <!-- -->
        <!-- <Style Selector="ListBoxItem:pointerover:selected  > ContentPresenter"> -->
        <!--     <Setter  Property="Background" Value="Transparent"></Setter> -->
        <!-- </Style> -->
    </Application.Styles>
</Application>